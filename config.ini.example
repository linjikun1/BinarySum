# BinarySum Configuration Template
# Copy this file to config.ini and fill in your API keys

# ========================================
# OpenAI API Configuration
# Add your profile sections below
# ========================================
[default]
api_key = YOUR_API_KEY_HERE
base_url = https://api.openai.com/v1
model_name = gpt-4

# Example: Custom API provider
# [aizex]
# api_key = YOUR_API_KEY_HERE
# base_url = https://aizex.top/v1
# model_name = gpt-4

# ========================================
# Generation Parameters
# ========================================
[generation_hpss]
temperature = 0.1
max_tokens = 4096

[generation_synthesis]
temperature = 0.1
max_tokens = 4096

[generation_sdn]
temperature = 0.1
max_tokens = 4096

# ========================================
# CCR (Cross-modal Code Retrieval) Configuration
# Training takes 10+ hours on 4x A100-80G GPUs
# Update yaml files in src/generate/capd/ccr/src/scripts/configs/ with your paths.
# ========================================
[ccr]
# Architecture tag (e.g., x64_O2, x64_O3, arm_O2)
arch = x64_O2

# Model paths (relative to ccr/save/<arch>/ or absolute paths)
casp_model = CASP/cg-casp-moco-lmpa-c-only
prober_model = src_prober_codellama-13b-last1unfreeze

# External model paths — set absolute paths to your downloaded models
asm_tokenizer_path = /path/to/models/longcodeart
src_model_path = /path/to/models/CodeLlama-13b-hf
codet5p_embedding_path = /path/to/models/codet5p-110m-embedding

# Generation parameters
max_new_tokens = 60
num_return_sequences = 5
temperature = 1.0
top_k = 500
top_p = 0.5
batch_size = 2
